{
    "name": "Youtube Notes",
    "description": "Take notes for videos directly on Youtube.com",
    "version": "1.0",
    "manifest_version": 3,
    "action": {
        "default_icon": "images/icon.png"
    },
    "permissions": ["commands"],
    "commands": {
        "reload": {
            "suggested_key": {
                "default": "Ctrl+R",
                "mac": "Command+R"
            },
            "description": "Reload the extension."
        }
    },
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "js": ["content.js"],
            "css": ["css/main.css", "css/bootstrap-scoped.css"],
            "matches": ["https://www.youtube.com/*"]
        }
    ],
    "web_accessible_resources": [
        {
            "resources": ["html/sidepanel.html"],
            "matches": ["https://www.youtube.com/*"]
        }
    ]
}
