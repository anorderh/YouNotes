{
    "name": "YouNotes",
    "description": "Write and save notes on Youtube",
    "version": "1.0.1",
    "manifest_version": 3,
    "action": {
        "default_popup": "html/popup.html"
    },
    "icons": {
        "16": "images/icons/younotes_3_128.png",
        "32": "images/icons/younotes_3_128.png",
        "48": "images/icons/younotes_48.png",
        "128": "images/icons/younotes_128.png"
    },
    "permissions": ["commands", "storage", "tabs", "unlimitedStorage"],
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "js": ["sidepanel.js"],
            "css": [
                "css/vars.css",
                "css/tiptap.css",
                "css/sidepanel.css",
                "css/extension.css",
                "css/bootstrap-utilities.min.css"
            ],
            "matches": ["https://www.youtube.com/*"]
        }
    ],
    "web_accessible_resources": [
        {
            "resources": ["html/*", "images/*"],
            "matches": ["https://www.youtube.com/*"]
        }
    ]
}
