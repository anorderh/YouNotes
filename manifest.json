{
    "name": "Youtube Notes",
    "description": "Take notes for videos directly on Youtube.com",
    "version": "1.0",
    "manifest_version": 3,
    "action": {
        "default_icon": "images/icon.png"
    },
    "content_scripts": [
        {
            "js": ["yt_content_script.js"],
            "css": ["yt_content_css.css"],
            "matches": ["https://www.youtube.com/watch*"]
        }
    ]
}
